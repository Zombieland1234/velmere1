# SITE
NEXT_PUBLIC_SITE_URL=http://localhost:3000
STORE_BASE_CURRENCY=EUR

# STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GEMINI AI
GEMINI_API_KEY=

# SUPABASE / DATABASE
NEXT_PUBLIC_SUPABASE_URL=https://...
SUPABASE_URL=https://...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# WEB3 (WalletConnect/Reown)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...

# SERVER SESSION / PREVIEW WRITE GUARD
VELMERE_SERVER_SESSION_SECRET=

# STORE READINESS / COMMERCE GATES
CHECKOUT_MODE=stripe
STORE_COMMERCIAL_READY=false
STORE_SELLER_ADDRESS_READY=false
STORE_SHIPPING_RATES_READY=false
STORE_RETURNS_POLICY_FINAL=false
STORE_PRIVACY_POLICY_FINAL=false
STORE_TAX_READY=false
STORE_FULFILMENT_READY=false

# PAID DIGITAL SERVICES / VLM ADVANCED GATES
# Set true only when Stripe, terms, tax handling and support flow are ready.
VELMERE_SERVICES_COMMERCIAL_READY=false
# Server-only secret, minimum 32 characters. Signs paid access tokens after Stripe confirms payment.
VELMERE_PAID_ACCESS_SECRET=
# Optional. Default is 30 days. Keep between 10 minutes and 365 days.
VELMERE_PAID_ACCESS_TTL_MS=2592000000
# Production hard mode: protected APIs require a durable Supabase entitlement row, not only a signed token.
VELMERE_REQUIRE_PAID_ENTITLEMENT_LEDGER=false

# ADMIN / IMPORTS
ADMIN_IMPORT_TOKEN=
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=
PRINTFUL_CONFIRM_ORDERS=false

# OPTIONAL LEGACY AI FALLBACKS
OPENAI_API_KEY=

# CONTACT / MAIL
CONTACT_TO_EMAIL=velmere141@gmail.com
CONTACT_FROM_EMAIL="Velmere <onboarding@resend.dev>"
RESEND_API_KEY=re_...

# Optional: improves reliability for Velmère Shield market data.
# Server-only. Do not use NEXT_PUBLIC_ for API keys.
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=

# VELMERE SHIELD / MARKET INTEGRITY
MARKET_INTEGRITY_CRON_SECRET=
# Optional: server-side persistent ledger uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# Optional comma-separated symbols or ids watched by the Shield rules engine.
VELMERE_SHIELD_WATCHLIST=BTC,ETH,SOL,OM,PEPE,DOGE,VLM

# Velmère / VLM Shield production data backbone
# Copy to .env.local for local development. Never commit real secrets.

# Market/data adapters
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=

# Evidence persistence
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Production rate limiting / queueing
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=

# Wallet / VLM access
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# AI provider
OPENAI_API_KEY=

# INTERNAL QA SURFACES — keep disabled on public production.
NEXT_PUBLIC_VELMERE_OPERATOR_DIAGNOSTICS=0
NEXT_PUBLIC_VELMERE_SHOW_PDF_QA=0

# PASS632–636 security runtime
# Shared durable limiter and audit receipts. Keep all values server-only.
VELMERE_RATE_LIMIT_DISABLED=0
VELMERE_AUDIT_APPEND_DISABLED=0
VELMERE_AUDIT_UPSTASH_KEY=velmere:audit:events
VELMERE_SECURITY_EVENT_UPSTASH_KEY=velmere:security:events
VELMERE_SECURITY_EVENT_UPSTASH_MAX=500
VELMERE_SECURITY_EVENT_APPEND_TIMEOUT_MS=950
# Long random server-only secret used to group repeated VLM attacks without storing raw content.
VELMERE_SECURITY_FINGERPRINT_SECRET=

# Velmère VLM Brain (server only)
# GEMINI_API_KEY is declared once above. Never prefix it with NEXT_PUBLIC_.
VELMERE_GEMINI_MODEL=gemini-3.5-flash
# Optional independent reviewer model. Defaults to VELMERE_GEMINI_MODEL.
VELMERE_GEMINI_SHADOW_MODEL=
# Minimum 32 characters. Enables signed, tamper-evident VLM analysis receipts.
VELMERE_VLM_RECEIPT_SECRET=
# Preferred public-verification mode. Values are base64-encoded PEM.
VELMERE_VLM_RECEIPT_ED25519_PRIVATE_KEY_B64=
VELMERE_VLM_RECEIPT_ED25519_PUBLIC_KEY_B64=
VELMERE_VLM_RECEIPT_ACTIVE_KEY_ID=
# JSON object: {"previous-key-id":"BASE64_ENCODED_PUBLIC_PEM"}
VELMERE_VLM_RECEIPT_PREVIOUS_PUBLIC_KEYS_JSON=
VELMERE_VLM_RECEIPT_TTL_MS=900000
VELMERE_GEMINI_TIMEOUT_MS=12000
VELMERE_GEMINI_MAX_PROMPT_TOKENS=12000
VELMERE_GEMINI_MAX_OUTPUT_TOKENS=2400
VELMERE_GEMINI_MAX_REQUESTS_PER_MINUTE=30
VELMERE_GEMINI_MAX_TOKENS_PER_MINUTE=180000
# Optional cost estimates used only for diagnostics/governance.
VELMERE_GEMINI_INPUT_USD_PER_MILLION=
VELMERE_GEMINI_OUTPUT_USD_PER_MILLION=
